FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8501

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.ui.txt /workspace/requirements.ui.txt
RUN pip install --no-cache-dir -r requirements.ui.txt

COPY . /workspace

EXPOSE 8501

CMD ["sh", "-c", "streamlit run frontend/streamlit_app.py --server.port ${PORT} --server.address 0.0.0.0"]
