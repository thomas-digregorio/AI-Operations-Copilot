APP_ENV=local
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/artifacts/app.db

# RAG / Embeddings (local-first)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
VECTOR_STORE=faiss
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Fallback behavior (if local models are unavailable)
USE_LLM_FALLBACK=true

# Paths
DATA_DIR=./data
MODEL_DIR=./data/artifacts/models
VECTOR_DIR=./data/artifacts/vector_index

# Optional hosted provider
OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_LLM_MODEL=gpt-4.1-mini
